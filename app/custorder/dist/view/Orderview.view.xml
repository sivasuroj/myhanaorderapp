<mvc:View controllerName="custorder.controller.Orderview"
    xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <tnt:ToolHeader id="shellLikeToolHeader" class="sapUiTinyMargin">
			<Button id="_IDGenButton1" icon="sap-icon://menu2" type="Transparent" tooltip="Menu" press=".onCollapseExpandPress">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData1" priority="NeverOverflow"/>
				</layoutData>
			</Button>
			<Image id="_IDGenImage" src="test-resources/sap/tnt/images/SAP_Logo.png" decorative="false" press="onLogoPressed" tooltip="SAP Logo" width="60px" height="30px">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData2" priority="NeverOverflow"/>
				</layoutData>
			</Image>
			<Title text="Prоduct Name" wrapping="false" id="productName">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData3" priority="Disappear"/>
				</layoutData>
			</Title>
			<Text text="Second title" wrapping="false" id="secondTitle">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData4" priority="Disappear"/>
				</layoutData>
			</Text>
			<ToolbarSpacer id="_IDGenToolbarSpacer" />
			<SearchField width="25rem" id="searchField">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData5" priority="Low" group="1"/>
				</layoutData>
			</SearchField>
			<Button visible="false" icon="sap-icon://search" type="Transparent" id="searchButton" tooltip="Search"/>
			<OverflowToolbarButton id="_IDGenOverflowToolbarButton" icon="sap-icon://da" type="Transparent" press=".onFetchSalesOrderData" tooltip="Joule" text="Joule">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData6" group="2"/>
				</layoutData>
			</OverflowToolbarButton>
			<OverflowToolbarButton id="_IDGenOverflowToolbarButton1" icon="sap-icon://source-code" type="Transparent" tooltip="Action 1" text="Action 1">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData7" group="2"/>
				</layoutData>
			</OverflowToolbarButton>
			<OverflowToolbarButton id="_IDGenOverflowToolbarButton2" icon="sap-icon://card" type="Transparent" tooltip="Action 2" text="Action 2">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData8" group="2"/>
				</layoutData>
			</OverflowToolbarButton>
			<OverflowToolbarButton id="_IDGenOverflowToolbarButton3" icon="sap-icon://action-settings" type="Transparent" text="Settings"/>
			<Button id="_IDGenButton2" icon="sap-icon://bell" type="Transparent" tooltip="Notification">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData9" priority="NeverOverflow"/>
				</layoutData>
			</Button>
			<tnt:ToolHeaderUtilitySeparator id="_IDGenToolHeaderUtilitySeparator"/>
			<OverflowToolbarButton id="_IDGenOverflowToolbarButton4" icon="sap-icon://grid" type="Transparent" text="My Products" tooltip="My Products"/>
			<Avatar id="_IDGenAvatar" src="test-resources/sap/tnt/images/Woman_avatar_01.png" displaySize="XS" press=".onAvatarPressed" tooltip="Profile">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData10" priority="NeverOverflow"/>
				</layoutData>
			</Avatar>
		</tnt:ToolHeader>
        <HBox id="_IDGenHBox2" >
                <VBox id="_IDGenVBox6" >
            <tnt:SideNavigation id="sideNavigation" selectedKey="walked" expanded="true">
			<tnt:NavigationList id="_IDGenNavigationList">
				<tnt:NavigationListItem id="_IDGenNavigationListItem2" text="Home" icon="sap-icon://home" />
				<tnt:NavigationListGroup id="_IDGenNavigationListGroup" text="New">
					<tnt:NavigationListItem id="_IDGenNavigationListItem3" text="Add Orders" icon="sap-icon://people-connected" press=".onAddOrdersPress"/>
					<tnt:NavigationListItem id="_IDGenNavigationListItem4" text="Building" icon="sap-icon://building" >
						<tnt:NavigationListItem id="_IDGenNavigationListItem5" text="Office 01" />
						<tnt:NavigationListItem id="_IDGenNavigationListItem6" text="Office 02" />
					</tnt:NavigationListItem>
					<tnt:NavigationListItem id="_IDGenNavigationListItem7" text="Mileage" icon="sap-icon://mileage" >
						<tnt:NavigationListItem id="_IDGenNavigationListItem8" text="Driven" />
						<tnt:NavigationListItem text="Walked" id="walked" />
					</tnt:NavigationListItem>
				</tnt:NavigationListGroup>
				<tnt:NavigationListGroup id="_IDGenNavigationListGroup1" text="Recently used">
					<tnt:NavigationListItem id="_IDGenNavigationListItem9" text="View Orders" icon="sap-icon://kpi-managing-my-area" press="onViewOrdersPress"/>
					<tnt:NavigationListItem id="_IDGenNavigationListItem10" text="Flight" icon="sap-icon://flight" />
					<tnt:NavigationListItem id="_IDGenNavigationListItem11" text="Map" icon="sap-icon://map-2" />
				</tnt:NavigationListGroup>
				<tnt:NavigationListGroup id="_IDGenNavigationListGroup2" text="Restricted" enabled="false">
					<tnt:NavigationListItem id="_IDGenNavigationListItem12" text="Running" icon="sap-icon://physical-activity" />
					<tnt:NavigationListItem id="_IDGenNavigationListItem13" text="Scissors" icon="sap-icon://scissors" />
				</tnt:NavigationListGroup>
				<tnt:NavigationListItem id="_IDGenNavigationListItem14" text="Transport" icon="sap-icon://passenger-train" />
			</tnt:NavigationList>
			<tnt:fixedItem>
				<tnt:NavigationList id="_IDGenNavigationList1">
					<tnt:NavigationListItem id="_IDGenNavigationListItem15" text="Bar Chart" icon="sap-icon://bar-chart" />
					<tnt:NavigationListItem id="_IDGenNavigationListItem16" selectable="false" href="https://sap.com" target="_blank" text="External Link" icon="sap-icon://attachment" />
					<tnt:NavigationListItem id="_IDGenNavigationListItem17" selectable="false" href="https://sap.com" target="_top" text="External Link _top" icon="sap-icon://attachment" />
					<tnt:NavigationListItem id="_IDGenNavigationListItem" text="Compare" icon="sap-icon://compare" />
				</tnt:NavigationList>
			</tnt:fixedItem>
		    </tnt:SideNavigation>
        
        </VBox>
        <VBox id="_IDGenVBox7" >

            <Panel id="addpanel" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
                <headerToolbar>
                    <OverflowToolbar id="_IDGenOverflowToolbar">
                        <Title id="_IDGenTitle" text="Panel with picture"/>
                    </OverflowToolbar>
                </headerToolbar>
                <Breadcrumbs id="_IDGenBreadcrumbs" >
                    <Link id="_IDGenLink" text="Master"></Link>
                </Breadcrumbs>

                <HBox id="_IDGenHBox" >
                    <VBox id="_IDGenVBox" >
                        <Label id="_IDGenLabel1" text="OrderID"></Label>
                        <Input id="_IDGenInput" placeholder="enter OrderID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox1" >
                        <Label id="_IDGenLabel2" text="CustomerID"></Label>
                        <Input id="_IDGenInput1" placeholder="enter CustomerID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox2" >
                        <Label id="_IDGenLabel3" text="EmployeeID"></Label>
                        <Input id="_IDGenInput2" placeholder="enter EmployeeID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox3" >
                        <Label id="_IDGenLabel4" text="ShipName"></Label>
                        <Input id="_IDGenInput3" placeholder="enter ShipName"></Input>
                    </VBox>
                </HBox>
                <HBox id="_IDGenHBox1" >
                    <VBox id="_IDGenVBox5" >
                    <Button id="_IDGenButton" press="submit" text="Submit" type="Default"></Button>
                    </VBox>
                </HBox>
            </Panel>
			<Panel id="addpanel1" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
				<Label id="_IDGenLabel" text ="Header Orders"></Label>
						<Table id="idProductsTable" items="{/Orders}">						
							
							<columns>
								<Column id="_IDGenColumn1"
									width="12em">
									<Text id="_IDGenText" text="OrderID" />
									
								</Column>
								<Column id="_IDGenColumn2"
									minScreenWidth="Tablet"
									demandPopin="true">
									<Text id="_IDGenText1" text="CustomerID" />
								</Column>
								<Column id="_IDGenColumn3"
									minScreenWidth="Desktop"
									demandPopin="true"
									hAlign="End">
									<Text id="_IDGenText2" text="EmployeeID" />
								</Column>
								<Column id="_IDGenColumn4"
									minScreenWidth="Desktop"
									demandPopin="true"
									hAlign="Center">
									<Text id="_IDGenText3" text="ShipVia" />
								</Column>
								<Column id="_IDGenColumn5"
									hAlign="End">
									<Text id="_IDGenText4" text="ShipName" />
								</Column>
								<Column id="_IDGenColumn51"
									hAlign="End">
									<Text id="_IDGenText41" text="Actions" />
								</Column>
							</columns>
							<items>
								<ColumnListItem id="_IDGenColumnListItem" vAlign="Middle">
									<cells>
										<Text id="_IDGenText0" text="{OrderID}" />
										<Text id="_IDGenText51" text="{CustomerID}" />
										<Text id="_IDGenText52" text="{EmployeeID}" />
										<Text id="_IDGenText53" text="{ShipVia}" />
										<Text id="_IDGenText54" text="{ShipName}" />
										<Button id="_IDGenButton3" text="..." press="OnActionPressed($event,this)"></Button>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
				
			</Panel>    
			<Panel id="addpanel2" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
                <headerToolbar>
                    <OverflowToolbar id="_IDGenOverflowToolbar1">
                        <Title id="_IDGenTitle1" text="Panel with picture"/>
                    </OverflowToolbar>
                </headerToolbar>
                <Breadcrumbs id="_IDGenBreadcrumbs1" >
                    <Link id="_IDGenLink1" text="Master"></Link>
                </Breadcrumbs>

                <HBox id="_IDGenHBox14" >
                    <VBox id="_IDGenVBox11" >
                        <Label id="_IDGenLabel110" text="OrderID"></Label>
                        <Input id="_IDGenInput17" placeholder="enter OrderID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox12" >
                        <Label id="_IDGenLabel12" text="CustomerID"></Label>
                        <Input id="_IDGenInput11" placeholder="enter CustomerID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox21" >
                        <Label id="_IDGenLabel31" text="EmployeeID"></Label>
                        <Input id="_IDGenInput21" placeholder="enter EmployeeID"></Input>
                    </VBox>
                    <VBox id="_IDGenVBox31" >
                        <Label id="_IDGenLabel41" text="ShipName"></Label>
                        <Input id="_IDGenInput31" placeholder="enter ShipName"></Input>
                    </VBox>
                </HBox>
                <HBox id="_IDGenHBox11" >
                    <VBox id="_IDGenVBox51" >
                    <Button id="_IDGenButton11" press="update" text="Update" type="Default"></Button>
                    </VBox>
                </HBox>
            </Panel>
        </VBox>
        
        </HBox>
        
        
    </Page>
</mvc:View>